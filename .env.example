# ─── App ───────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Redis (BullMQ) ────────────────────────────────────
REDIS_URL=redis://cert-sender-redis:6379

# ─── Gotenberg (PDF) ───────────────────────────────────
GOTENBERG_URL=http://gotenberg:3000

# ─── Base de datos SQLite ──────────────────────────────
DB_PATH=/app/data/db/cert-sender.db

# ─── Encriptación (contraseñas SMTP en DB) ─────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=cambia_esto_por_una_clave_hex_de_64_caracteres

# ─── Asunto y cuerpo del email (por defecto) ───────────
EMAIL_SUBJECT=Tu certificado de participación
EMAIL_BODY=Estimado/a {nombre},\n\nAdjunto encontrarás tu certificado de participación.\n\nGracias por tu asistencia.
