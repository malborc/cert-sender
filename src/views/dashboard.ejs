<%- include('partials/_head', { title: 'Dashboard', currentPath: '/' }) %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
  <p class="mt-1 text-sm text-gray-500">Resumen del sistema de certificados</p>
</div>

<!-- Stats cards -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <div class="bg-white rounded-lg shadow-sm p-5 border border-gray-100">
    <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Campañas</p>
    <p class="mt-1 text-3xl font-bold text-indigo-600"><%= stats.total_campaigns %></p>
  </div>
  <div class="bg-white rounded-lg shadow-sm p-5 border border-gray-100">
    <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Enviados</p>
    <p class="mt-1 text-3xl font-bold text-green-600"><%= stats.total_sent.toLocaleString() %></p>
  </div>
  <div class="bg-white rounded-lg shadow-sm p-5 border border-gray-100">
    <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Errores</p>
    <p class="mt-1 text-3xl font-bold text-red-500"><%= stats.total_errors.toLocaleString() %></p>
  </div>
  <div class="bg-white rounded-lg shadow-sm p-5 border border-gray-100">
    <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Perfiles SMTP</p>
    <p class="mt-1 text-3xl font-bold text-gray-700"><%= stats.total_smtp %></p>
  </div>
</div>

<!-- Quick actions -->
<div class="flex gap-3 mb-6">
  <a href="/campaigns/new"
     class="inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-700 shadow-sm">
    + Nueva campaña
  </a>
  <a href="/templates/new"
     class="inline-flex items-center px-4 py-2 bg-white text-gray-700 text-sm font-medium rounded-md border border-gray-300 hover:bg-gray-50 shadow-sm">
    + Nueva plantilla
  </a>
  <a href="/smtp/new"
     class="inline-flex items-center px-4 py-2 bg-white text-gray-700 text-sm font-medium rounded-md border border-gray-300 hover:bg-gray-50 shadow-sm">
    + Perfil SMTP
  </a>
</div>

<!-- Recent campaigns -->
<div class="bg-white shadow-sm rounded-lg border border-gray-100 overflow-hidden">
  <div class="px-5 py-4 border-b border-gray-100">
    <h2 class="text-sm font-semibold text-gray-700">Campañas recientes</h2>
  </div>
  <% if (campaigns.length === 0) { %>
    <div class="px-5 py-10 text-center text-sm text-gray-400">
      No hay campañas aún. <a href="/campaigns/new" class="text-indigo-600 hover:underline">Crea la primera</a>.
    </div>
  <% } else { %>
  <table class="min-w-full divide-y divide-gray-100">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Campaña</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">Estado</th>
        <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase">Asistentes</th>
        <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase">Enviados</th>
        <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase">Errores</th>
        <th class="px-5 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-50">
      <% campaigns.forEach(c => { %>
      <tr class="hover:bg-gray-50">
        <td class="px-5 py-3">
          <div class="font-medium text-gray-900 text-sm"><%= c.name %></div>
          <div class="text-xs text-gray-400"><%= c.event_date || '' %></div>
        </td>
        <td class="px-5 py-3">
          <%
            const badges = {
              draft:   'bg-gray-100 text-gray-600',
              sending: 'bg-blue-100 text-blue-700',
              paused:  'bg-yellow-100 text-yellow-700',
              done:    'bg-green-100 text-green-700',
              error:   'bg-red-100 text-red-600',
            };
            const badge = badges[c.status] || badges.draft;
          %>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= badge %>">
            <%= c.status %>
          </span>
        </td>
        <td class="px-5 py-3 text-right text-sm text-gray-700"><%= c.total.toLocaleString() %></td>
        <td class="px-5 py-3 text-right text-sm text-green-600 font-medium"><%= c.sent.toLocaleString() %></td>
        <td class="px-5 py-3 text-right text-sm text-red-500"><%= c.errors %></td>
        <td class="px-5 py-3 text-right">
          <a href="/campaigns/<%= c.id %>" class="text-indigo-600 hover:underline text-xs font-medium">Ver</a>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } %>
</div>

<%- include('partials/_foot') %>
