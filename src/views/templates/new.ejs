<%- include('../partials/_head', { title, currentPath }) %>

<div class="mb-6">
  <a href="/templates" class="text-sm text-gray-500 hover:text-gray-700">← Plantillas</a>
  <h1 class="mt-1 text-2xl font-bold text-gray-900">Nueva plantilla SVG</h1>
</div>

<% if (error) { %>
<div class="mb-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded text-sm"><%= error %></div>
<% } %>

<div class="max-w-lg bg-white rounded-lg border border-gray-100 shadow-sm p-6">
  <form action="/templates" method="POST" enctype="multipart/form-data">
    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-1">Nombre de la plantilla</label>
      <input type="text" name="name" placeholder="Certificado Congreso 2026"
             class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
    </div>
    <div class="mb-6">
      <label class="block text-sm font-medium text-gray-700 mb-1">Archivo SVG <span class="text-red-500">*</span></label>
      <input type="file" name="svg" accept=".svg,image/svg+xml" required
             class="w-full text-sm text-gray-600 border border-gray-300 rounded-md px-3 py-2 file:mr-3 file:border-0 file:bg-indigo-50 file:text-indigo-700 file:text-sm file:font-medium file:rounded file:cursor-pointer hover:file:bg-indigo-100" />
      <p class="mt-1 text-xs text-gray-400">Tamaño máximo 10 MB. El nombre del asistente se superpondrá en la posición que configures en el siguiente paso.</p>
    </div>
    <button type="submit"
            class="w-full px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-700 shadow-sm">
      Subir y configurar posición →
    </button>
  </form>
</div>

<%- include('../partials/_foot') %>
