<% const current = locals.currentPath || ''; %>
<% const links = [
  { href: '/',          label: 'Dashboard',   icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { href: '/campaigns', label: 'Campañas',    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2' },
  { href: '/templates', label: 'Plantillas',  icon: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z' },
  { href: '/smtp',      label: 'SMTP',        icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
]; %>
<% links.forEach(link => { %>
  <% const active = (link.href === '/' ? current === '/' : current.startsWith(link.href)); %>
  <a href="<%= link.href %>"
     class="group flex items-center px-2 py-2 text-sm font-medium rounded-md
            <%= active ? 'bg-indigo-900 text-white' : 'text-indigo-100 hover:bg-indigo-700 hover:text-white' %>">
    <svg class="mr-3 h-5 w-5 flex-shrink-0 <%= active ? 'text-indigo-300' : 'text-indigo-400 group-hover:text-indigo-300' %>"
         fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="<%= link.icon %>" />
    </svg>
    <%= link.label %>
  </a>
<% }); %>
