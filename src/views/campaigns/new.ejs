<%- include('../partials/_head', { title, currentPath }) %>

<div class="mb-6">
  <a href="/campaigns" class="text-sm text-gray-500 hover:text-gray-700">← Campañas</a>
  <h1 class="mt-1 text-2xl font-bold text-gray-900">Nueva campaña</h1>
</div>

<% if (error) { %>
<div class="mb-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded text-sm"><%= error %></div>
<% } %>

<div class="max-w-2xl bg-white rounded-lg border border-gray-100 shadow-sm p-6">
  <form action="/campaigns" method="POST">

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Nombre del evento <span class="text-red-500">*</span></label>
        <input type="text" name="name" required placeholder="Congreso Anual 2026"
               class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Fecha del evento</label>
        <input type="date" name="event_date"
               class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Perfil SMTP</label>
        <select name="smtp_profile_id"
                class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
          <option value="">— Seleccionar —</option>
          <% smtpProfiles.forEach(s => { %>
          <option value="<%= s.id %>"><%= s.name %></option>
          <% }); %>
        </select>
        <% if (smtpProfiles.length === 0) { %>
        <p class="mt-1 text-xs text-amber-600">No hay perfiles SMTP. <a href="/smtp/new" class="underline">Crea uno primero</a>.</p>
        <% } %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Plantilla SVG</label>
        <select name="template_id"
                class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
          <option value="">— Seleccionar —</option>
          <% templates.forEach(t => { %>
          <option value="<%= t.id %>"><%= t.name %></option>
          <% }); %>
        </select>
        <% if (templates.length === 0) { %>
        <p class="mt-1 text-xs text-amber-600">No hay plantillas. <a href="/templates/new" class="underline">Sube una primero</a>.</p>
        <% } %>
      </div>
    </div>

    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-1">Asunto del email</label>
      <input type="text" name="email_subject" value="Tu certificado de participación"
             class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
    </div>

    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-1">Cuerpo del email</label>
      <p class="text-xs text-gray-400 mb-1">Usa <code class="bg-gray-100 px-1 rounded">{nombre}</code> para insertar el nombre del asistente.</p>
      <textarea name="email_body" rows="5"
                class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-500">Estimado/a {nombre},

Adjunto encontrarás tu certificado de participación.

Gracias por tu asistencia.</textarea>
    </div>

    <div class="grid grid-cols-2 gap-4 mb-6">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Emails por lote</label>
        <input type="number" name="batch_size" value="30" min="1" max="500"
               class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Intervalo entre lotes (min)</label>
        <input type="number" name="batch_interval_min" value="10" min="1" max="120"
               class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
      </div>
    </div>

    <button type="submit"
            class="w-full px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-700 shadow-sm">
      Crear campaña →
    </button>
  </form>
</div>

<%- include('../partials/_foot') %>
