<%- include('../partials/_head', { title, currentPath }) %>

<div class="mb-5 flex items-start justify-between gap-4">
  <div>
    <a href="/campaigns" class="text-sm text-gray-500 hover:text-gray-700">← Campañas</a>
    <h1 class="mt-1 text-2xl font-bold text-gray-900"><%= campaign.name %></h1>
    <p class="text-sm text-gray-500"><%= campaign.event_date || '' %> &nbsp;•&nbsp; Lotes de <%= campaign.batch_size %> c/u cada <%= campaign.batch_interval_min %> min</p>
  </div>
  <div class="flex gap-2 flex-shrink-0">
    <% if (['draft','paused','error'].includes(campaign.status) && stats.pending > 0) { %>
    <form action="/send/<%= campaign.id %>/start" method="POST">
      <button class="px-4 py-2 bg-green-600 text-white text-sm font-medium rounded-md hover:bg-green-700 shadow-sm">
        Iniciar envío
      </button>
    </form>
    <% } %>
    <% if (campaign.status === 'sending') { %>
    <form action="/send/<%= campaign.id %>/pause" method="POST">
      <button class="px-4 py-2 bg-yellow-500 text-white text-sm font-medium rounded-md hover:bg-yellow-600 shadow-sm">
        Pausar
      </button>
    </form>
    <% } %>
    <a href="/attendees/export/<%= campaign.id %>"
       class="px-4 py-2 bg-white text-gray-700 text-sm font-medium rounded-md border border-gray-300 hover:bg-gray-50 shadow-sm">
      Exportar CSV
    </a>
  </div>
</div>

<!-- Stats -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
  <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-4 text-center">
    <p class="text-xs text-gray-500 uppercase font-medium">Total</p>
    <p class="text-2xl font-bold text-gray-800 mt-1"><%= stats.total.toLocaleString() %></p>
  </div>
  <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-4 text-center">
    <p class="text-xs text-gray-500 uppercase font-medium">Pendientes</p>
    <p class="text-2xl font-bold text-indigo-600 mt-1"><%= stats.pending.toLocaleString() %></p>
  </div>
  <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-4 text-center">
    <p class="text-xs text-gray-500 uppercase font-medium">Enviados</p>
    <p class="text-2xl font-bold text-green-600 mt-1"><%= stats.sent.toLocaleString() %></p>
  </div>
  <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-4 text-center">
    <p class="text-xs text-gray-500 uppercase font-medium">Errores</p>
    <p class="text-2xl font-bold text-red-500 mt-1"><%= stats.errors %></p>
  </div>
</div>

<!-- Progress bar -->
<% if (stats.total > 0) { %>
<div class="bg-white rounded-lg border border-gray-100 shadow-sm p-4 mb-6" id="progress-section">
  <div class="flex justify-between text-xs text-gray-500 mb-1">
    <span>Progreso de envío</span>
    <span id="progress-pct"><%= Math.round((stats.sent / stats.total) * 100) %>%</span>
  </div>
  <div class="w-full bg-gray-100 rounded-full h-3">
    <div id="progress-bar" class="bg-green-500 h-3 rounded-full transition-all"
         style="width:<%= Math.round((stats.sent / stats.total) * 100) %>%"></div>
  </div>
  <% if (campaign.status === 'sending') { %>
  <p class="text-xs text-blue-600 mt-2 animate-pulse">Enviando en lotes…</p>
  <% } %>
</div>
<% } %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

  <!-- CSV Upload -->
  <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-5">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">Cargar asistentes (CSV)</h2>
    <p class="text-xs text-gray-400 mb-3">Columnas requeridas: <code class="bg-gray-100 px-1 rounded">email</code>, <code class="bg-gray-100 px-1 rounded">asistente</code></p>
    <% if (longestName) { %>
    <p class="text-xs text-gray-500 mb-3">Nombre más largo: <strong class="text-gray-800"><%= longestName %></strong></p>
    <% } %>
    <form id="csv-form" action="/attendees/upload/<%= campaign.id %>" method="POST" enctype="multipart/form-data">
      <input type="file" name="csv" accept=".csv" required
             class="w-full text-xs text-gray-600 border border-gray-300 rounded px-2 py-1.5 mb-3 file:mr-2 file:border-0 file:bg-indigo-50 file:text-indigo-700 file:text-xs file:font-medium file:rounded file:cursor-pointer" />
      <button type="submit"
              class="w-full px-3 py-2 bg-indigo-600 text-white text-xs font-medium rounded hover:bg-indigo-700">
        Importar CSV
      </button>
    </form>
    <% if (stats.pending > 0) { %>
    <form action="/attendees/clear/<%= campaign.id %>" method="POST"
          onsubmit="return confirm('¿Eliminar asistentes pendientes?')" class="mt-2">
      <button class="w-full px-3 py-1.5 bg-red-50 text-red-600 text-xs font-medium rounded hover:bg-red-100">
        Limpiar pendientes
      </button>
    </form>
    <% } %>
  </div>

  <!-- Template preview -->
  <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-5">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">Certificado</h2>
    <% if (campaign.tmpl_id) { %>
      <img src="/templates/<%= campaign.tmpl_id %>/svg" alt="Plantilla"
           class="w-full rounded border border-gray-100 mb-3" />
      <div class="flex gap-2">
        <a href="/templates/<%= campaign.tmpl_id %>/edit"
           class="flex-1 text-center text-xs font-medium px-3 py-1.5 bg-gray-50 text-gray-700 rounded hover:bg-gray-100">
          Editar posición
        </a>
        <% if (longestName) { %>
        <a href="/send/<%= campaign.id %>/preview-pdf" target="_blank"
           class="flex-1 text-center text-xs font-medium px-3 py-1.5 bg-green-50 text-green-700 rounded hover:bg-green-100">
          Ver PDF
        </a>
        <% } %>
      </div>
    <% } else { %>
      <p class="text-xs text-amber-600">Sin plantilla asignada. <a href="/templates/new" class="underline">Sube una</a> y edita la campaña.</p>
    <% } %>
  </div>

  <!-- Config summary -->
  <div class="bg-white rounded-lg border border-gray-100 shadow-sm p-5">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">Configuración</h2>
    <dl class="space-y-2 text-xs">
      <div class="flex justify-between"><dt class="text-gray-500">SMTP</dt><dd class="text-gray-800 font-medium truncate max-w-36"><%= campaign.smtp_name || '—' %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Desde</dt><dd class="text-gray-800 truncate max-w-36"><%= campaign.from_email || '—' %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Asunto</dt><dd class="text-gray-800 truncate max-w-36"><%= campaign.email_subject %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Lote</dt><dd class="text-gray-800"><%= campaign.batch_size %> emails</dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Intervalo</dt><dd class="text-gray-800"><%= campaign.batch_interval_min %> min</dd></div>
    </dl>
    <form action="/campaigns/<%= campaign.id %>" method="POST" class="mt-4 space-y-2">
      <input type="hidden" name="name" value="<%= campaign.name %>" />
      <input type="hidden" name="event_date" value="<%= campaign.event_date || '' %>" />
      <input type="hidden" name="email_subject" value="<%= campaign.email_subject %>" />
      <input type="hidden" name="email_body" value="<%= campaign.email_body %>" />
      <div class="flex gap-2">
        <div class="flex-1">
          <label class="text-xs text-gray-500">Lote</label>
          <input type="number" name="batch_size" value="<%= campaign.batch_size %>" min="1"
                 class="w-full border border-gray-300 rounded px-2 py-1 text-xs" />
        </div>
        <div class="flex-1">
          <label class="text-xs text-gray-500">Intervalo (min)</label>
          <input type="number" name="batch_interval_min" value="<%= campaign.batch_interval_min %>" min="1"
                 class="w-full border border-gray-300 rounded px-2 py-1 text-xs" />
        </div>
      </div>
      <select name="smtp_profile_id" class="w-full border border-gray-300 rounded px-2 py-1 text-xs">
        <option value="">— SMTP —</option>
        <% smtpProfiles.forEach(s => { %>
        <option value="<%= s.id %>" <%= campaign.smtp_profile_id == s.id ? 'selected' : '' %>><%= s.name %></option>
        <% }); %>
      </select>
      <select name="template_id" class="w-full border border-gray-300 rounded px-2 py-1 text-xs">
        <option value="">— Plantilla —</option>
        <% templates.forEach(t => { %>
        <option value="<%= t.id %>" <%= campaign.template_id == t.id ? 'selected' : '' %>><%= t.name %></option>
        <% }); %>
      </select>
      <button class="w-full px-3 py-1.5 bg-gray-100 text-gray-700 text-xs font-medium rounded hover:bg-gray-200">
        Actualizar config
      </button>
    </form>
  </div>
</div>

<!-- Attendees table -->
<% if (recentAttendees.length > 0) { %>
<div class="mt-6 bg-white shadow-sm rounded-lg border border-gray-100 overflow-hidden">
  <div class="px-5 py-3 border-b border-gray-100 flex justify-between items-center">
    <h2 class="text-sm font-semibold text-gray-700">Asistentes (últimos <%= recentAttendees.length %>)</h2>
    <a href="/attendees/export/<%= campaign.id %>" class="text-xs text-indigo-600 hover:underline">Exportar todos</a>
  </div>
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-50 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500">Nombre</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500">Email</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500">Estado</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500">Enviado</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% recentAttendees.forEach(a => {
          const b = { pending:'bg-gray-100 text-gray-500', sent:'bg-green-100 text-green-700',
                      error:'bg-red-100 text-red-600', skipped:'bg-yellow-100 text-yellow-600' };
        %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-2 text-gray-900"><%= a.name %></td>
          <td class="px-4 py-2 text-gray-500"><%= a.email %></td>
          <td class="px-4 py-2">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= b[a.status] || b.pending %>">
              <%= a.status %>
            </span>
            <% if (a.error_msg) { %>
            <span class="ml-1 text-xs text-red-400" title="<%= a.error_msg %>">(!)</span>
            <% } %>
          </td>
          <td class="px-4 py-2 text-xs text-gray-400"><%= a.sent_at ? a.sent_at.split('T')[0] : '—' %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<!-- Auto-refresh when sending -->
<% if (campaign.status === 'sending') { %>
<script>
  setTimeout(() => location.reload(), 10000);
</script>
<% } %>

<%- include('../partials/_foot') %>
